.product-card {
  margin-bottom: 18rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #ffffff;
  display: grid;
  grid-template-columns: 150rpx 1fr;
  gap: 18rpx;
  box-shadow: 0 12rpx 34rpx rgba(15, 23, 42, 0.06);
}

.product-image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 14rpx;
  overflow: hidden;
  background: #eef2f1;
}

.fallback-cover {
  background: linear-gradient(135deg, #e8f5f3, #d4ede9);
  color: #0f766e;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 54rpx;
  font-weight: 900;
}

.product-info {
  min-width: 0;
}

.product-head {
  display: flex;
  gap: 12rpx;
  align-items: center;
  justify-content: space-between;
}

.product-name {
  min-width: 0;
  color: #111827;
  font-size: 30rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cook-time {
  flex-shrink: 0;
  color: #0f766e;
  font-size: 22rpx;
}

.tag-row {
  min-height: 34rpx;
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  padding: 5rpx 10rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #64748b;
  font-size: 20rpx;
}

.stock-warning {
  display: inline-flex;
  margin-top: 8rpx;
  padding: 5rpx 10rpx;
  border-radius: 999rpx;
  background: #fff7ed;
  color: #e8692a;
  font-size: 20rpx;
  font-weight: 700;
}

.stock-warning.empty {
  background: #f1f5f9;
  color: #64748b;
}

.product-desc {
  height: 34rpx;
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 34rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-foot {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.price-box {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.member-badge {
  padding-left: 8rpx;
  border-left: 5rpx solid #f97316;
  background: transparent;
  color: #c2410c;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.2;
  white-space: nowrap;
}

.price {
  color: #f97316;
  font-weight: 800;
}

.origin-price {
  margin-left: 8rpx;
  color: #94a3b8;
  font-size: 20rpx;
  text-decoration: line-through;
}

.stepper,
.quantity-tools {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.qty-btn {
  width: 46rpx;
  height: 46rpx;
  border-radius: 10rpx;
  border: 2rpx solid #dbe3ea;
  background: #ffffff;
  color: #334155;
  font-size: 30rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.06);
}

.qty-btn.add {
  border-color: #0f766e;
  background: #0f766e;
  color: #ffffff;
  box-shadow: 0 6rpx 14rpx rgba(15, 118, 110, 0.22);
}

.qty-btn[disabled] {
  border-color: #e2e8f0;
  background: #f8fafc;
  color: #cbd5e1;
  box-shadow: none;
}

.qty-text {
  min-width: 42rpx;
  height: 42rpx;
  padding: 0 6rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 8rpx;
  background: #f8fafc;
  text-align: center;
  color: #0f172a;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 42rpx;
}
