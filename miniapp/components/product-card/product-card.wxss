.product-card {
  margin-bottom: 18rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #ffffff;
  display: grid;
  grid-template-columns: 150rpx 1fr;
  gap: 18rpx;
  box-shadow: 0 12rpx 34rpx rgba(15, 23, 42, 0.06);
}

.product-image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 14rpx;
  overflow: hidden;
}

.fallback-cover {
  background: linear-gradient(135deg, #ecfeff, #fff7ed);
  color: #0f766e;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 54rpx;
  font-weight: 900;
}

.product-info {
  min-width: 0;
}

.product-head {
  display: flex;
  gap: 12rpx;
  align-items: center;
  justify-content: space-between;
}

.product-name {
  min-width: 0;
  color: #111827;
  font-size: 30rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cook-time {
  flex-shrink: 0;
  color: #0f766e;
  font-size: 22rpx;
}

.tag-row {
  min-height: 34rpx;
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  padding: 5rpx 10rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #64748b;
  font-size: 20rpx;
}

.product-desc {
  height: 34rpx;
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 34rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-foot {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.price-box {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.member-badge {
  padding: 4rpx 8rpx;
  border-radius: 8rpx;
  background: #fff7ed;
  color: #f97316;
  font-size: 19rpx;
  font-weight: 800;
}

.price {
  color: #f97316;
  font-weight: 800;
}

.origin-price {
  margin-left: 8rpx;
  color: #94a3b8;
  font-size: 20rpx;
  text-decoration: line-through;
}

.stepper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.qty-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #e2e8f0;
  color: #0f172a;
  font-size: 34rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qty-btn.add {
  background: #0f766e;
  color: #ffffff;
}

.qty-btn[disabled] {
  background: #cbd5e1;
}

.qty-text {
  min-width: 32rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 800;
}
