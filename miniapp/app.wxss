page {
  min-height: 100vh;
  background: #f6f7f9;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
}

view,
text,
scroll-view,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border-radius: 0;
  background: transparent;
  color: inherit;
  line-height: 1;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
}

.safe-bottom {
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.primary-btn {
  height: 88rpx;
  border-radius: 16rpx;
  background: #0f766e;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.primary-btn[disabled] {
  background: #cbd5e1;
  color: #ffffff;
}

.ghost-btn {
  height: 76rpx;
  border-radius: 14rpx;
  border: 2rpx solid #d1d5db;
  color: #374151;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.muted {
  color: #6b7280;
}

.price {
  color: #f97316;
  font-weight: 800;
}

.empty {
  min-height: 360rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  align-items: center;
  justify-content: center;
  color: #6b7280;
  font-size: 28rpx;
}

.empty-mark {
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  background: #e5e7eb;
  color: #64748b;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  font-weight: 800;
}
