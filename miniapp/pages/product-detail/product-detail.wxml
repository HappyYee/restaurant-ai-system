<view class="page detail-page safe-bottom">
  <view wx:if="{{loading}}" class="empty">
    <view class="empty-mark">餐</view>
    <text>正在读取菜品</text>
  </view>

  <view wx:elif="{{!product}}" class="empty">
    <view class="empty-mark">空</view>
    <text>菜品不存在或已下架</text>
  </view>

  <view wx:else>
    <image wx:if="{{product.imageUrl && !imageFailed}}" class="hero-image" src="{{product.imageUrl}}" mode="aspectFill" lazy-load binderror="onImageError" />
    <view wx:else class="hero-image detail-cover">
      <text>{{product.coverText}}</text>
    </view>

    <view class="detail-main">
      <view class="detail-head">
        <view>
          <view class="name">{{product.name}}</view>
          <view class="category">{{product.category}} · {{product.cookTime}}分钟出餐</view>
        </view>
        <view class="detail-price">
          <text class="member-badge">{{product.memberDiscountLabel || '会员价'}}</text>
          <text class="price">¥{{product.priceText}}</text>
          <text class="origin-price">原价 ¥{{product.originalPriceText}}</text>
        </view>
      </view>

      <view class="tag-row">
        <text wx:for="{{tags}}" wx:key="*this" class="tag">{{item}}</text>
      </view>

      <view class="section">
        <view class="section-title">菜品介绍</view>
        <view class="description">{{product.description}}</view>
      </view>

      <view wx:if="{{product.stockWarningText}}" class="stock-warning {{product.stock <= 0 ? 'empty' : ''}}">
        <text>{{product.stockWarningText}}</text>
      </view>

      <view class="quantity-row">
        <text>购买数量</text>
        <view class="quantity-tools">
          <button class="qty-btn minus" disabled="{{quantity <= 0}}" bindtap="decrease">−</button>
          <text class="qty-text">{{quantity}}</text>
          <button class="qty-btn add" bindtap="increase">+</button>
        </view>
      </view>
    </view>

    <view class="bottom-actions">
      <button class="ghost-btn" bindtap="addToCart">{{quantity ? '加入购物车' : '移除购物车'}}</button>
      <button class="primary-btn" bindtap="goConfirm">立即下单</button>
    </view>
  </view>
</view>
