.detail-page {
  padding-bottom: 170rpx;
}

.hero-image {
  width: 100%;
  height: 420rpx;
  border-radius: 22rpx;
  overflow: hidden;
  background: #eef2f1;
}

.detail-cover {
  background: linear-gradient(135deg, #ecfeff, #fff7ed);
  color: #0f766e;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 128rpx;
  font-weight: 900;
}

.detail-main {
  margin-top: 22rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 36rpx rgba(15, 23, 42, 0.06);
}

.detail-head {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.name {
  font-size: 42rpx;
  font-weight: 900;
  color: #111827;
}

.category {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #64748b;
}

.detail-price {
  flex-shrink: 0;
  text-align: right;
}

.detail-price .price {
  display: block;
  font-size: 40rpx;
}

.member-badge {
  display: inline-block;
  margin-bottom: 8rpx;
  padding-left: 10rpx;
  border-left: 6rpx solid #f97316;
  background: transparent;
  color: #c2410c;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.2;
}

.origin-price {
  display: block;
  margin-top: 4rpx;
  color: #94a3b8;
  font-size: 22rpx;
  text-decoration: line-through;
}

.tag-row {
  margin-top: 22rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #0f766e;
  font-size: 22rpx;
}

.section {
  margin-top: 34rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #111827;
}

.description {
  margin-top: 14rpx;
  color: #4b5563;
  font-size: 26rpx;
  line-height: 1.65;
}

.quantity-row {
  min-height: 96rpx;
  margin-top: 20rpx;
  border-top: 2rpx solid #f1f5f9;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: #374151;
}

.stock-warning {
  margin-top: 22rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  background: #fff7ed;
  color: #e8692a;
  font-size: 24rpx;
  font-weight: 800;
}

.stock-warning.empty {
  background: #f1f5f9;
  color: #64748b;
}

.quantity-tools {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.qty-btn {
  width: 66rpx;
  height: 66rpx;
  border-radius: 14rpx;
  border: 2rpx solid #dbe3ea;
  background: #ffffff;
  color: #334155;
  font-size: 36rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 14rpx rgba(15, 23, 42, 0.06);
}

.qty-btn.add {
  border-color: #0f766e;
  background: #0f766e;
  color: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(15, 118, 110, 0.24);
}

.qty-btn[disabled] {
  border-color: #e2e8f0;
  background: #f8fafc;
  color: #cbd5e1;
  box-shadow: none;
}

.qty-text {
  min-width: 72rpx;
  height: 64rpx;
  padding: 0 8rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 12rpx;
  background: #f8fafc;
  text-align: center;
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 64rpx;
}

.bottom-actions {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: grid;
  grid-template-columns: 1fr 1.6fr;
  gap: 18rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 18rpx 45rpx rgba(15, 23, 42, 0.16);
}

.bottom-actions .ghost-btn {
  border: 2rpx solid #0f766e;
  color: #0f766e;
  background: #ffffff;
}

.bottom-actions .primary-btn {
  border-radius: 18rpx;
  background: #0f766e;
  box-shadow: 0 10rpx 24rpx rgba(15, 118, 110, 0.28);
}
