.index-page {
  min-height: 100vh;
  padding-bottom: 32rpx;
  display: flex;
  flex-direction: column;
}

.index-page.has-cart {
  padding-bottom: 260rpx;
}

.hero {
  min-height: 248rpx;
  padding: 32rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #083344 0%, #0f766e 52%, #f97316 100%);
  color: #ffffff;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 24rpx;
}

.hero-label {
  display: inline-flex;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 22rpx;
}

.hero-title {
  margin-top: 22rpx;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1.05;
}

.hero-subtitle {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
}

.hero-card {
  width: 132rpx;
  height: 132rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.16);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.hero-card text:first-child {
  font-size: 42rpx;
  font-weight: 900;
}

.hero-card text:last-child {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.82);
}

.stats-bar {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10rpx;
  min-height: 56rpx;
  margin: 18rpx 0 12rpx;
  color: #64748b;
  font-size: 23rpx;
}

.stats-bar__item text {
  color: #0f766e;
  font-weight: 900;
}

.stats-bar__divider {
  color: #cbd5e1;
}

.search-bar {
  min-height: 76rpx;
  margin-bottom: 18rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.05);
}

.search-icon {
  color: #94a3b8;
  font-size: 34rpx;
  line-height: 1;
}

.search-input {
  flex: 1;
  min-width: 0;
  color: #111827;
  font-size: 26rpx;
}

.search-clear {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f1f5f9;
  color: #64748b;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-layout {
  flex: 1;
  min-height: 620rpx;
  display: grid;
  grid-template-columns: 164rpx 1fr;
  gap: 18rpx;
}

.category-list,
.product-list {
  height: 100%;
}

.category-item {
  min-height: 88rpx;
  padding: 18rpx 14rpx;
  border-radius: 14rpx;
  color: #64748b;
  font-size: 26rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  justify-content: center;
}

.category-item.active {
  background: #ffffff;
  color: #0f766e;
  font-weight: 800;
  box-shadow: 0 12rpx 30rpx rgba(15, 118, 110, 0.12);
}

.category-count {
  font-size: 20rpx;
  color: #94a3b8;
}

.product-card {
  margin-bottom: 18rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #ffffff;
  display: grid;
  grid-template-columns: 150rpx 1fr;
  gap: 18rpx;
  box-shadow: 0 12rpx 34rpx rgba(15, 23, 42, 0.06);
}

.product-image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 14rpx;
  overflow: hidden;
}

.fallback-cover {
  background: linear-gradient(135deg, #ecfeff, #fff7ed);
  color: #0f766e;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 54rpx;
  font-weight: 900;
}

.product-info {
  min-width: 0;
}

.product-head {
  display: flex;
  gap: 12rpx;
  align-items: center;
  justify-content: space-between;
}

.product-name {
  min-width: 0;
  color: #111827;
  font-size: 30rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cook-time {
  flex-shrink: 0;
  color: #0f766e;
  font-size: 22rpx;
}

.tag-row {
  min-height: 34rpx;
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  padding: 5rpx 10rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #64748b;
  font-size: 20rpx;
}

.product-desc {
  height: 34rpx;
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 34rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-foot {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.stepper {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.qty-btn {
  width: 46rpx;
  height: 46rpx;
  border-radius: 10rpx;
  border: 2rpx solid #dbe3ea;
  background: #ffffff;
  color: #334155;
  font-size: 30rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.06);
}

.qty-btn.add {
  border-color: #0f766e;
  background: #0f766e;
  color: #ffffff;
  box-shadow: 0 6rpx 14rpx rgba(15, 118, 110, 0.22);
}

.qty-btn[disabled] {
  border-color: #e2e8f0;
  background: #f8fafc;
  color: #cbd5e1;
  box-shadow: none;
}

.qty-text {
  min-width: 42rpx;
  height: 42rpx;
  padding: 0 6rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 8rpx;
  background: #f8fafc;
  text-align: center;
  color: #0f172a;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 42rpx;
}

.floating-cart {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(132rpx + env(safe-area-inset-bottom));
  min-height: 104rpx;
  padding: 14rpx 16rpx;
  border-radius: 999rpx;
  background: #1a2e2b;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  z-index: 100;
  box-shadow: 0 18rpx 45rpx rgba(26, 46, 43, 0.35);
}

.floating-cart__icon {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #0f766e;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.floating-cart__badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 6rpx;
  border-radius: 999rpx;
  background: #e8692a;
  color: #ffffff;
  font-size: 18rpx;
  line-height: 30rpx;
  text-align: center;
}

.floating-cart__main {
  flex: 1;
  min-width: 0;
}

.cart-title {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.cart-price {
  margin-top: 8rpx;
  font-size: 36rpx;
  font-weight: 900;
}

.cart-btn {
  width: 180rpx;
  height: 76rpx;
  border-radius: 16rpx;
  background: #f97316;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-btn[disabled] {
  background: #475569;
}

.retry-btn {
  width: 220rpx;
  margin-top: 12rpx;
}
