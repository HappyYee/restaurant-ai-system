<view class="page index-page safe-bottom {{cartSummary.totalQuantity ? 'has-cart' : ''}}">
  <view class="hero">
    <view>
      <view class="hero-label">今日营业中</view>
      <view class="hero-title">星禾小馆</view>
      <view class="hero-subtitle">现点现做 · 明厨出餐 · 门店自取</view>
    </view>
    <view class="hero-card">
      <text>{{storeStats.productCount}}</text>
      <text>款在售</text>
    </view>
  </view>

  <view class="stats-bar">
    <text class="stats-bar__item">快手餐品 <text>{{storeStats.fastCount}}</text> 款</text>
    <text class="stats-bar__divider">·</text>
    <text class="stats-bar__item">已选 <text>{{cartSummary.totalQuantity}}</text> 件</text>
    <text class="stats-bar__divider">·</text>
    <text class="stats-bar__item">在售 <text>{{storeStats.productCount}}</text> 款</text>
  </view>

  <view class="search-bar">
    <text class="search-icon">⌕</text>
    <input class="search-input" placeholder="搜索菜品、口味、标签" value="{{keyword}}" bindinput="onSearchInput" />
    <button wx:if="{{keyword}}" class="search-clear" bindtap="clearSearch">×</button>
  </view>

  <view wx:if="{{loading}}" class="empty">
    <view class="empty-mark">餐</view>
    <text>正在读取菜单</text>
  </view>

  <view wx:elif="{{errorMessage}}" class="empty">
    <view class="empty-mark">!</view>
    <text>{{errorMessage}}</text>
    <button class="primary-btn retry-btn" bindtap="loadProducts">重新加载</button>
  </view>

  <view wx:elif="{{!viewProducts.length}}" class="empty">
    <view class="empty-mark">空</view>
    <text>{{keyword ? '没有找到匹配菜品' : '暂无可售菜品'}}</text>
    <button wx:if="{{keyword}}" class="primary-btn retry-btn" bindtap="clearSearch">清空搜索</button>
  </view>

  <view wx:else class="menu-layout">
    <scroll-view class="category-list" scroll-y>
      <view
        wx:for="{{categories}}"
        wx:key="name"
        class="category-item {{activeCategory === item.name ? 'active' : ''}}"
        data-category="{{item.name}}"
        bindtap="setCategory"
      >
        <text>{{item.name}}</text>
        <text class="category-count">{{item.count}}</text>
      </view>
    </scroll-view>

    <scroll-view class="product-list" scroll-y>
      <product-card
        wx:for="{{viewProducts}}"
        wx:key="id"
        product="{{item}}"
        bind:cardtap="goDetail"
        bind:addcart="addProduct"
        bind:minuscart="minusProduct"
      />
    </scroll-view>
  </view>

  <view wx:if="{{cartSummary.totalQuantity}}" class="floating-cart active">
    <view class="floating-cart__icon">
      <text>购</text>
      <text class="floating-cart__badge">{{cartSummary.totalQuantity}}</text>
    </view>
    <view class="floating-cart__main">
      <view class="cart-title">已选 {{cartSummary.totalQuantity}} 件</view>
      <view class="cart-price">¥{{cartSummary.totalAmountText}}</view>
    </view>
    <button class="cart-btn" disabled="{{!cartSummary.totalQuantity}}" bindtap="goConfirm">去结算</button>
  </view>
</view>
