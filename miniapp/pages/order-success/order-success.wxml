<view class="page success-page">
  <view class="success-card">
    <view class="success-mark">✓</view>
    <view class="success-title">订单已提交</view>
    <view class="success-subtitle">后厨会尽快接单制作</view>

    <view class="order-box">
      <view class="order-row">
        <text>订单编号</text>
        <text>{{orderNo}}</text>
      </view>
      <view class="order-row">
        <text>订单金额</text>
        <text class="price">¥{{amountText}}</text>
      </view>
      <view wx:if="{{pointsUsed > 0}}" class="order-row">
        <text>积分抵扣</text>
        <text>-{{pointsUsed}}分 / ¥{{pointsDiscountText}}</text>
      </view>
      <view class="order-row">
        <text>本单获得</text>
        <text>{{pointsEarned}} 积分</text>
      </view>
    </view>

    <view class="action-grid">
      <button class="ghost-btn" bindtap="goMenu">继续点餐</button>
      <button class="primary-btn" bindtap="goOrders">查看订单</button>
    </view>
  </view>
</view>
