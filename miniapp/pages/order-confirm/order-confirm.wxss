.confirm-page {
  padding-bottom: 170rpx;
}

.panel,
.summary-panel {
  margin-bottom: 22rpx;
  padding: 26rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 36rpx rgba(15, 23, 42, 0.06);
}

.panel-title {
  margin-bottom: 20rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.cart-item {
  display: grid;
  grid-template-columns: 132rpx 1fr;
  gap: 18rpx;
  padding: 20rpx 0;
  border-top: 2rpx solid #f1f5f9;
}

.cart-item:first-of-type {
  border-top: 0;
}

.item-image {
  width: 132rpx;
  height: 132rpx;
  border-radius: 14rpx;
  overflow: hidden;
}

.fallback-cover {
  padding: 16rpx;
  background: #ecfeff;
  color: #0f766e;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.item-main {
  min-width: 0;
}

.item-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #111827;
}

.item-meta {
  margin-top: 10rpx;
  color: #64748b;
  font-size: 22rpx;
}

.item-foot {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.stepper {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.qty-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #e2e8f0;
  color: #0f172a;
  font-size: 34rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qty-btn.add {
  background: #0f766e;
  color: #ffffff;
}

.qty-text {
  min-width: 36rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 900;
}

.pickup-card {
  padding: 22rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.pickup-title {
  color: #111827;
  font-size: 28rpx;
  font-weight: 800;
}

.pickup-subtitle {
  margin-top: 10rpx;
  color: #64748b;
  font-size: 22rpx;
}

.pickup-badge {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #ccfbf1;
  color: #0f766e;
  font-size: 22rpx;
  font-weight: 800;
}

.remark {
  width: 100%;
  height: 148rpx;
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  color: #111827;
  font-size: 26rpx;
  line-height: 1.5;
}

.summary-row {
  min-height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #4b5563;
  font-size: 26rpx;
}

.summary-row.total {
  margin-top: 12rpx;
  padding-top: 18rpx;
  border-top: 2rpx solid #f1f5f9;
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.submit-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  min-height: 116rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: #111827;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  box-shadow: 0 18rpx 45rpx rgba(15, 23, 42, 0.22);
}

.submit-label {
  color: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
}

.submit-price {
  margin-top: 8rpx;
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 900;
}

.submit-btn {
  width: 250rpx;
  flex-shrink: 0;
}

.empty-btn {
  width: 220rpx;
  margin-top: 12rpx;
}
