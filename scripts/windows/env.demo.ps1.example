# Copy this file to scripts/windows/env.demo.ps1 and fill in local values.
# env.demo.ps1 is ignored by Git so secrets are not uploaded.

$env:MYSQL_HOST = "localhost"
$env:MYSQL_PORT = "3306"
$env:MYSQL_DATABASE = "restaurant_ai"
$env:MYSQL_USERNAME = "root"
$env:MYSQL_PASSWORD = "your_mysql_password"

# Optional. If omitted, backend AI endpoints fall back to local rules.
$env:DEEPSEEK_API_KEY = ""
$env:DEEPSEEK_MODEL = "deepseek-v4-pro"

# Admin web calls this backend URL in the browser.
$env:VITE_API_BASE_URL = "http://127.0.0.1:8080/api"
